{
  "name": "api-health-monitor",
  "displayName": "API Health Monitor",
  "description": "Monitor your AI API usage, cost and health in real-time",
  "version": "0.0.1",
  "publisher": "jallad",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ES7/api-health-monitor"
  },
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "apiHealthMonitor",
          "title": "API Health Monitor",
          "icon": "$(pulse)"
        }
      ]
    },
    "views": {
      "apiHealthMonitor": [
        {
          "type": "webview",
          "id": "apiHealthMonitor.dashboard",
          "name": "Dashboard"
        }
      ]
    },
    "commands": [
      {
        "command": "apiHealthMonitor.refresh",
        "title": "API Health Monitor: Refresh Dashboard"
      },
      {
        "command": "apiHealthMonitor.clearData",
        "title": "API Health Monitor: Clear All Data"
      },
      {
        "command": "apiHealthMonitor.scanWorkspace",
        "title": "API Health Monitor: Scan Workspace for APIs"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.120.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}